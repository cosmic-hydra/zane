# Optional Hugging Face token for gated models
HF_TOKEN=

# Web search integrations
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_ID=

# Optional PubMed API key for higher request throughput
NCBI_API_KEY=

# Cerebras API key for hosted chat guidance
CEREBRAS_API_KEY=
CEREBRAS_MODEL=llama-3.3-70b

# Optional path to local Go search binary
ZANE_GO_SEARCH_BIN=

# Dashboard AI defaults
ZANE_DASHBOARD_AI=1
ZANE_AI_MODEL_ID=artifacts/llama/tinyllama-1.1b-chat

# Runtime paths
ZANE_DATA_DIR=data
ZANE_CHECKPOINT_DIR=checkpoints
ZANE_LOG_DIR=logs
ZANE_OUTPUT_DIR=outputs
